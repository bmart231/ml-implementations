    "import numpy as np\n",
    "\n",
    "# inputs (3 features)\n",
    "x = np.array([1.0, 2.0, 3.0])\n",
    "\n",
    "# weights and bias for one neuron\n",
    "w = np.array([0.2, 0.8, -0.5])\n",
    "b = 2.0\n",
    "\n",
    "# forward pass: weighted sum + bias\n",
    "z = np.dot(x, w) + b\n",
    "print(z)"
   ]
  }
